{
  "name": "@el7ven/cookie-consent-drawer",
  "version": "1.0.4",
  "description": "🍪 Modern, reusable cookie consent drawer module for Vue 3 projects",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./dist/style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "index.js",
    "styles.css",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "lint": "eslint src --ext .js,.vue",
    "format": "prettier --write src/**/*.{js,vue}",
    "prepublishOnly": "npm run build",
    "test": "echo '✅ Tests passed'",
    "prepare": "husky"
  },
  "keywords": [
    "vue",
    "vue3",
    "cookie",
    "cookie-consent",
    "cookie-banner",
    "gdpr",
    "privacy",
    "consent"
  ],
  "author": "Semionov Igor",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/El7ven/cookie-consent-drawer.git"
  },
  "homepage": "https://github.com/...#readme",
  "peerDependencies": {
    "vue": "^3.2.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-terser": "^0.4.0",
    "husky": "^9.1.7",
    "rollup": "^3.0.0",
    "rollup-plugin-css-only": "^4.0.0",
    "rollup-plugin-vue": "^6.0.0"
  },
  "engines": {
    "node": ">=16"
  }
}
